// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../site/src/app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Models
model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  name                  String?
  passwordHash          String    @default("")
  emailVerified         DateTime?
  image                 String?
  businessName          String?
  logo                  String?
  address               String?
  phone                 String?
  shopRate              Float?
  overheadRate          Float?
  defaultMargin         Float?
  showDetailedBreakdown Boolean   @default(true)
  onboardingCompleted   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  projects       Project[]
  materialPrices MaterialPrice[]
  templates      Template[]
}

model Project {
  id                String    @id @default(uuid())
  userId            String
  status            String    @default("draft") // draft, sent, accepted, declined, completed
  title             String
  description       String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  furnitureType     String?
  style             String?
  complexityTier    String?
  lengthIn          Float?
  widthIn           Float?
  heightIn          Float?
  photoUrls         String? // JSON array stored as text
  aiAnalysis        String? // JSON stored as text
  shopRate          Float?
  overheadRate      Float?
  marginPercent     Float?
  subtotal          Float?
  tax               Float?
  total             Float?
  shareToken        String?   @unique
  paymentTerms      String?
  estimatedTimeline String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  sentAt            DateTime?
  acceptedAt        DateTime?
  completedAt       DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems LineItem[]

  @@index([userId])
  @@index([status])
}

model LineItem {
  id          String  @id @default(uuid())
  projectId   String
  category    String // material, labor, hardware, finish, other
  name        String
  description String?
  quantity    Float
  unit        String
  unitCost    Float
  totalCost   Float
  sortOrder   Int     @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model MaterialPrice {
  id           String   @id @default(uuid())
  userId       String?
  category     String // lumber, plywood, hardware, finish, other
  name         String
  species      String?
  grade        String?
  unit         String
  pricePerUnit Float
  supplier     String?
  lastUpdated  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model Template {
  id               String  @id @default(uuid())
  userId           String
  name             String
  furnitureType    String?
  style            String?
  defaultLineItems String? // JSON stored as text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
